{
  "name": "cli-remote-agent",
  "version": "1.0.0",
  "description": "Remote-control agent for Claude Remote Controller: exposes a terminal, file explorer, and Claude Code session bridge on this machine to your self-hosted CRC server.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arose-Niazi/claude-remote-controller.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/Arose-Niazi/claude-remote-controller/tree/main/packages/agent#readme",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "crc-agent": "dist/index.js",
    "crc-agent-setup": "dist/setup.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "service:install": "node dist/service-install.js",
    "service:uninstall": "node dist/service-uninstall.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@crc/shared": "*",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
