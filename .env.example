# --- Server configuration (copy to .env and fill in) ---

PORT=3001
DATA_DIR=/app/data
NODE_ENV=production

# Admin account. On first boot an "admin" user is seeded from this password.
# Use a long, unique value.
ADMIN_PASSWORD=change-me

# HMAC signing key for auth tokens and file download URLs.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# OPTIONAL — legacy single-user agent map, adopted as the admin's agents on first
# boot for backward compatibility. New agents should be enrolled per-user instead.
# AGENTS={"agent-id":"REPLACE_WITH_LONG_RANDOM_SECRET"}

# OPTIONAL — comma-separated allowed web origins for CORS (defaults to same-origin).
# ALLOWED_ORIGINS=https://your-domain.example

# OPTIONAL — token lifetime in days (default 30).
# TOKEN_TTL_DAYS=30

# --- Web Push (VAPID). Generate a keypair, e.g.:  npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
